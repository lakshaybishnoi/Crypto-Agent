# FastAPI application runtime
ENVIRONMENT=local
LOG_LEVEL=INFO
APP_HOST=0.0.0.0
APP_PORT=8000
HOST_PORT=8000

# Optional command override. Leave empty to auto-run crypto_agent.main:app with uvicorn.
# Example worker mode: CRYPTO_AGENT_CMD="python3 -m crypto_agent.runner"
CRYPTO_AGENT_CMD=
CRYPTO_AGENT_MODE=paper
CRYPTO_AGENT_TIMEZONE=UTC

# Market universe and signal cadence
QUOTE_ASSET=USDT
TOP_ASSET_LIMIT=5
SIGNAL_INTERVAL_SECONDS=60
SIGNAL_COOLDOWN_SECONDS=900
# Tuned 2026-07 via walk-forward search (crypto_agent.evaluation.optimize).
# Profit config: 4h trend-following, ~45% hit rate, +1.1%/trade on 6-month held-out
# test (BTC/ETH/SOL). Re-run `make optimize` before changing.
SIGNAL_TIMEFRAMES=4h,1d
MINIMUM_CONFIDENCE=0.45
REGIME_FILTER=trending
STOP_ATR_MULTIPLIER=3.0
TARGET_R_MULTIPLE=1.5
# Alternative high-hit-rate config (67% OOS hit rate, ~breakeven expectancy):
# SIGNAL_TIMEFRAMES=1m,15m + REGIME_FILTER empty + STOP_ATR_MULTIPLIER=2.0 + TARGET_R_MULTIPLE=0.5
BACKFILL_CANDLES=200
CRYPTO_AGENT_SYMBOLS=BTC/USDT,ETH/USDT,SOL/USDT
CRYPTO_AGENT_TIMEFRAME=5m
CRYPTO_AGENT_POLL_INTERVAL_SECONDS=60
EXCHANGE_PROVIDER=binance

# Provider endpoints
COINGECKO_BASE_URL=https://api.coingecko.com/api/v3
BINANCE_STREAM_BASE_URL=wss://stream.binance.com:9443/stream

# Safety and signal gating
SAFETY_DRY_RUN=true
KILL_SWITCH=false
SIGNAL_MIN_CONFIDENCE=0.70
MAX_SIGNALS_PER_HOUR=6
MAX_POSITION_RISK_PCT=1.0
MAX_DAILY_LOSS_PCT=3.0
ALLOW_LIVE_TRADING=false
PAPER_STARTING_BALANCE=10000
PAPER_MAX_ACTIVE_TRADES=5
PAPER_FEE_BPS=10
PAPER_SLIPPAGE_BPS=5

# Telegram notifications
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PARSE_MODE=Markdown

# Exchange and market data credentials
BINANCE_API_KEY=
BINANCE_API_SECRET=
COINBASE_API_KEY=
COINBASE_API_SECRET=
COINGECKO_API_KEY=

# Storage and logs
DATA_DIR=./data
LOG_DIR=./logs
SQLITE_PATH=./data/crypto_agent.sqlite3
DATABASE_URL=postgresql+asyncpg://crypto:crypto@postgres:5432/crypto_agent
REDIS_URL=redis://redis:6379/0
POSTGRES_DB=crypto_agent
POSTGRES_USER=crypto
POSTGRES_PASSWORD=crypto

# Health checks
CRYPTO_AGENT_HEALTHCHECK_URL=http://127.0.0.1:8000/health
CRYPTO_AGENT_HEALTHCHECK_CMD=

# Optional diagnostics
DOCTOR_REQUIRE_TELEGRAM=false
DOCTOR_NETWORK=false
